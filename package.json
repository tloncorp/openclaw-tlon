{
  "name": "@tloncorp/openclaw",
  "version": "0.1.0",
  "description": "OpenClaw Tlon/Urbit channel plugin",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "dev": "./dev/run.sh",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint --type-aware",
    "lint:fix": "pnpm format:fix && oxlint --type-aware --fix",
    "test": "vitest run src/",
    "test:security": "vitest run src/security.test.ts",
    "test:watch": "vitest src/",
    "test:integration": "bash ./test/run.sh",
    "test:integration:dev": "./test/run-dev.sh",
    "test:integration:watch": "./test/run-dev.sh --watch",
    "test:all": "vitest run"
  },
  "dependencies": {
    "@tloncorp/api": "github:tloncorp/api-beta#c5eb1720d94435b62503605acb294ef42a5440b3",
    "@tloncorp/tlon-skill": "^0.2.2",
    "@urbit/aura": "^3.0.0",
    "@urbit/http-api": "^3.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "devDependencies": {
    "dotenv": "^17.2.4",
    "openclaw": "2026.2.25",
    "oxfmt": "0.27.0",
    "oxlint": "^1.42.0",
    "oxlint-tsgolint": "^0.12.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "zod": "^4.3.6"
  },
  "openclaw": {
    "channel": {
      "id": "tlon",
      "label": "Tlon",
      "selectionLabel": "Tlon (Urbit)",
      "docsPath": "/channels/tlon",
      "docsLabel": "tlon",
      "blurb": "decentralized messaging on Urbit; install the plugin to enable.",
      "order": 90,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@tloncorp/openclaw",
      "localPath": "extensions/tlon",
      "defaultChoice": "npm"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tloncorp/openclaw-tlon.git"
  },
  "license": "MIT"
}
