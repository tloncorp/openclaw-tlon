# ── Minimal config (enough for `pnpm test:integration`) ──────────────

# Required: at least one LLM provider key
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (default: openrouter/minimax/minimax-m2.1)
# MODEL=openrouter/minimax/minimax-m2.1

# ── Extended config (for `pnpm test:integration:dev` / `pnpm dev`) ───

# Local Urbit ship connection
# NOTE: Use host.docker.internal (not localhost) to reach your host machine from Docker
TLON_URL=http://host.docker.internal:8080
TLON_SHIP=~zod
TLON_CODE=lidlut-tabwed-pillex-ridrup

# Test user ship (sends DMs to the bot)
TEST_USER_URL=http://host.docker.internal:8081
TEST_USER_SHIP=~ten
TEST_USER_CODE=lapseg-nolmel-riswen-hopryc

# Ships allowed to DM the bot (your ship for testing)
TLON_DM_ALLOWLIST=~ten

# Owner ship - receives approval requests for DMs, channel mentions, and group invites
TLON_OWNER_SHIP=~ten

# Gateway port (default: 18789)
# OPENCLAW_GATEWAY_PORT=18789

# ── Optional features ────────────────────────────────────────────────

# Brave Search API key — enables web_search (Brave provider) + image_search tool
# Get one at: https://brave.com/search/api/
# BRAVE_API_KEY=BSA...

# GitHub token for fetching tlonbot prompts in CI (not needed if ../tlonbot exists)
# TLONBOT_TOKEN=ghp_...

# Gateway auth token (auto-generated if not set)
# OPENCLAW_GATEWAY_TOKEN=your-stable-token-here

# ── Storage for media upload tests (optional) ─────────────────────────
# S3-compatible storage credentials for the media upload integration test.
# Without these, the media test is skipped; all other tests run normally.
# For GCS S3 interoperability, use HMAC keys from:
#   https://console.cloud.google.com/storage/settings;tab=interoperability

# TEST_STORAGE_ENDPOINT=https://storage.googleapis.com
# TEST_STORAGE_BUCKET=your-bucket-name
# TEST_STORAGE_ACCESS_KEY=GOOG...
# TEST_STORAGE_SECRET_KEY=...
# TEST_STORAGE_REGION=auto
